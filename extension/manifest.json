{
  "manifest_version": 3,
  "name": "Whisper Daemon Tab Capture",
  "version": "0.1.0",
  "description": "Capture tab audio for transcription by whisper-daemon",
  "permissions": ["tabCapture", "offscreen", "tabs", "notifications", "activeTab"],
  "host_permissions": ["https://meet.google.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content.js", "overlay.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Whisper Daemon"
  },
  "web_accessible_resources": [
    {
      "resources": ["pcm-processor.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
